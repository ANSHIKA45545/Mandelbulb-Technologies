# Server
PORT=5000
NODE_ENV=development

# PostgreSQL — pick ONE option below:

# Option A (recommended, no install): Prisma local Postgres
#   1. Run: npm run db:start
#   2. Run: npm run db:sync    (writes connection URL to this file)
#   3. Run: npm run db:push
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=YOUR_KEY_AFTER_db:sync"

# Option B: Docker — docker compose up -d (from project root)
# DATABASE_URL="postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public"

# Option C: Cloud (Neon/Supabase) — paste your connection string
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
GEMINI_API_KEY=your-gemini-api-key
